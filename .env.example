# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bookchiki

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT
# python -c "import secrets; print(secrets.token_hex(32))" 로 생성
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=bookchiki-images
AWS_REGION=ap-northeast-2

# OpenSearch
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200

# Aladin API
ALADIN_API_KEY=your-aladin-ttb-key

# AI APIs
OPENAI_API_KEY=your-openai-api-key
# OpenAI 임베딩 모델 (기본값: text-embedding-3-small, 1536차원)
# 변경 시 OpenSearch 인덱스 재생성 필요 (차원 수 맞춰야 함)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
TAVILY_API_KEY=your-tavily-api-key

# App
FRONTEND_URL=http://localhost:3000
